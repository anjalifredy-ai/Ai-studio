# Copy this file to .env.local for local development.
# On Vercel: Project Settings → Environment Variables → add each of these.

# Groq — free tier, get key at https://console.groq.com/keys
GROQ_API_KEY=

# Google Gemini — free tier, get key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# DeepSeek — get key at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# OpenRouter — free models available, get key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Your deployed site URL (used by OpenRouter's required header)
SITE_URL=https://your-app.vercel.app